ta-gill-v16] .toc-part-item__progress{\n  width:44px;height:1.75px;border-radius:99px;background:color-mix(in srgb,var(--gb-accent-gold) 20%,transparent);overflow:hidden;\n}\n[data-gill-v16] .toc-part-item__progress i{\n  display:block;height:100%;background:linear-gradient(90deg,var(--gb-accent-gold-bright),var(--gb-accent-gold));\n  border-radius:99px;\n  transition:width .42s var(--gb-ease-precise);\n}\n[data-gill-v16] .toc-part-item.is-current .toc-part-item__progress i{\n  background:linear-gradient(90deg,#ffd18b,var(--gb-accent-gold-bright));\n  box-shadow:0 0 6px rgba(216,170,109,.65);\n}\n\n/* v15: ACTION BAR at bottom of Part TOC — Save button fits here */\n[data-gill-v16] .toc-sheet__actions{\n  display:flex;align-items:center;gap:8px;\n  padding:14px 22px;\n  border-top:1px solid var(--gb-border);\n  background:color-mix(in srgb,var(--gb-surface) 92%,var(--gb-surface-muted));\n}\nhtml.dark [data-gill-v16] .toc-sheet__actions{background:color-mix(in srgb,var(--gb-surface) 92%,var(--gb-surface-muted))}\n[data-gill-v16] .toc-action-btn{\n  display:inline-flex;align-items:center;gap:8px;\n  padding:9px 14px;\n  border:1px solid var(--gb-border);\n  border-radius:10px;\n  background:var(--gb-surface);\n  font-family:var(--gb-font-sans);\n  font-size:13px;font-weight:600;color:var(--gb-text);\n  cursor:pointer;\n  transition:\n[data-gill-v16] border-color .22s var(--gb-ease-out),[data-gill-v16] \n[data-gill-v16] color .22s var(--gb-ease-out),[data-gill-v16] \n[data-gill-v16] background .22s var(--gb-ease-out),[data-gill-v16] \n    transform .18s var(--gb-ease-precise);\n}\n[data-gill-v16] .toc-action-btn:hover{\n  border-color:var(--gb-accent);\n  color:var(--gb-accent);\n}\n[data-gill-v16] .toc-action-btn:active{transform:scale(.96)}\n[data-gill-v16] .toc-action-btn svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;transition:fill .22s,stroke .22s}\n[data-gill-v16] .toc-action-btn.is-saved{\n  background:color-mix(in srgb,var(--gb-accent-gold) 8%,transparent);\n  border-color:var(--gb-accent-gold);\n  color:var(--gb-accent-gold-deep);\n}\n[data-gill-v16] .toc-action-btn.is-saved svg{\n  fill:var(--gb-accent-gold);\n  stroke:var(--gb-accent-gold);\n}\n[data-gill-v16] .toc-action-btn--ghost{\n  background:transparent;\n  border-color:transparent;\n  color:var(--gb-text-muted);\n}\n[data-gill-v16] .toc-action-btn--ghost:hover{\n  background:var(--gb-surface-muted);\n  border-color:var(--gb-border);\n  color:var(--gb-text);\n}\n\n/* TOAST */\n\n/* KEYBOARD HELP */\n\n\n[data-gill-v16] .roman-grid{\n  display:grid;grid-template-columns:repeat(6,1fr);gap:8px;\n}\n@media(max-width:680px){.roman-grid{grid-template-columns:repeat(4,1fr)}}\n[data-gill-v16] .roman-cell{\n  border:1px solid var(--gb-border);\n  border-radius:10px;\n  background:linear-gradient(180deg,#1f1512 0%,#120e0d 100%);\n  padding:18px 8px 10px;\n  display:flex;flex-direction:column;align-items:center;gap:6px;\n  cursor:pointer;\n  transition:\n[data-gill-v16] background .28s var(--gb-ease-out),[data-gill-v16] \n[data-gill-v16] border-color .28s var(--gb-ease-out),[data-gill-v16] \n    transform .32s var(--gb-ease-spring);\n  transform-origin:center;\n  position:relative;\n}\n@media (hover: hover) and (pointer: fine) {\n[data-gill-v16] .roman-cell:hover{\n    background:linear-gradient(180deg,#2a1c17 0%,#1a1311 100%);\n    border-color:rgba(216,170,109,.30);\n    transform:translateY(-2px);\n  }\n}\n[data-gill-v16] .roman-cell:active{transform:translateY(0) scale(.98)}\n[data-gill-v16] .roman-cell.is-current{\n  background:rgba(216,170,109,.10);\n  border-color:rgba(216,170,109,.40);\n}\n[data-gill-v16] .roman-cell__num{\n  font-family:var(--gb-font-serif-display);\n  font-size:22px;font-weight:600;font-style:italic;letter-spacing:.02em;\n  color:var(--gb-accent-gold);line-height:1;\n  transition:color .22s var(--gb-ease-out),transform .32s var(--gb-ease-spring);\n}\n@media (hover: hover) and (pointer: fine) {\n[data-gill-v16] .roman-cell:hover .roman-cell__num{color:var(--gb-accent-gold-bright);transform:scale(1.15)}\n}\n[data-gill-v16] .roman-cell.is-current .roman-cell__num{\n  color:var(--gb-accent-gold-bright);\n  text-shadow:0 0 12px rgba(216,170,109,.35);\n}\n[data-gill-v16] .roman-cell__time{\n  font-family:var(--gb-font-sans);\n  font-size:9px;font-weight:700;letter-spacing:.10em;text-transform:uppercase;\n  color:rgba(255,255,255,.45);\n}\n[data-gill-v16] .roman-cell.is-current .roman-cell__time{color:#e17c5e}\n\n@media (prefers-reduced-motion: reduce){\n}\n\n/* ============================================================\n   v16 POPUP & BAR RESPONSIVE BEHAVIOR (for Arena demo & Real Devices)\n   ============================================================ */\n@media (max-width: 960px) {\n[data-gill-v16] .toc-overlay {\n    padding: 0 !important;\n    align-items: flex-end !important;\n  }\n[data-gill-v16] .toc-sheet {\n    width: 100% !important;\n    max-height: 85vh;\n    border-radius: 24px 24px 0 0;\n    border-left: none; border-right: none; border-bottom: none;\n  }\n[data-gill-v16] .toc-sheet__head {\n    padding: 16px 18px 12px;\n  }\n[data-gill-v16] .toc-sheet__head .back {\n    left: 12px; top: 16px;\n  }\n[data-gill-v16] .toc-part-item {\n    padding: 11px 18px;\n    gap: 10px;\n    grid-template-columns: 28px 1fr auto;\n  }\n[data-gill-v16] .toc-part-item__num {\n    font-size: 13.5px;\n  }\n[data-gill-v16] .toc-sheet__actions {\n    padding: 12px 16px max(14px, env(safe-area-inset-bottom, 14px));\n    gap: 8px;\n  }\n[data-gill-v16] .toc-action-btn {\n    padding: 9px 12px;\n    font-size: 13px;\n    border-radius: 10px;\n  }\n[data-gill-v16] .toc-action-btn.gb-save {\n    flex: 1 1 auto;\n    justify-content: center;\n  }\n}\n@media (max-width: 500px) {\n[data-gill-v16] .toc-sheet__actions .toc-action-btn--ghost .btn-lbl {\n    display: none;\n  }\n[data-gill-v16] .toc-sheet__actions .toc-action-btn--ghost {\n    padding: 9px;\n    width: 38px;\n    min-width: 38px;\n    justify-content: center;\n  }\n}\n\n/* ============================================================\n   v16 OWNER FEEDBACK FIXES (Dark Theme Glow + Grid TOC Head & Actions)\n   ============================================================ */\nhtml.dark [data-gill-v16] .gb-ember {\n  --ring-color: #eed093 !important;\n  color: #eed093 !important;\n  box-shadow: 0 0 16px rgba(245, 197, 66, 0.35), inset 0 0 12px rgba(245, 197, 66, 0.15) !important;\n}\nhtml.dark [data-gill-v16] .gb-ember::after {\n  filter: drop-shadow(0 0 4px #f5c542);\n}\nhtml.dark [data-gill-v16] .mobile-btoc-progress-track {\n  background: rgba(216, 176, 104, 0.16) !important;\n}\nhtml.dark [data-gill-v16] .mobile-btoc-progress-fill {\n  background: linear-gradient(90deg, #eed093, #c59b58) !important;\n  box-shadow: 0 0 8px rgba(216, 176, 104, 0.35) !important;\n}\nhtml.dark [data-gill-v16] .toc-part-item.is-current .toc-part-item__progress i {\n  background: linear-gradient(90deg, #eed093, #c59b58) !important;\n  box-shadow: 0 0 8px rgba(216, 176, 104, 0.38) !important;\n}\nhtml.dark [data-gill-v16] .toc-part-item__num {\n  color: #eed093 !important;\n}\nhtml.dark [data-gill-v16] .toc-part-item.is-current .toc-part-item__num {\n  color: #ffd18b !important;\n  text-shadow: 0 0 12px rgba(216, 176, 104, 0.45) !important;\n}\n\n[data-gill-v16] .toc-sheet__head--grid {\n  display: grid !important;\n  grid-template-columns: 36px 1fr !important;\n  gap: 14px !important;\n  align-items: center !important;\n  padding: 16px 22px 14px !important;\n}\n[data-gill-v16] .toc-sheet__head--grid .back {\n  position: static !important;\n  width: 36px !important; height: 36px !important;\n  border-radius: 10px !important;\n  display: grid !important; place-items: center !important;\n  background: var(--gb-surface-muted) !important;\n  color: var(--gb-text) !important;\n  padding: 0 !important; margin: 0 !important;\n}\n[data-gill-v16] .toc-sheet__head--grid .toc-head-txt { min-width: 0 !important; }\n[data-gill-v16] .toc-sheet__head--grid .toc-head-txt .lab { margin-bottom: 3px !important; }\n[data-gill-v16] .toc-sheet__head--grid .toc-head-txt h3 { white-space: nowrap !important; overflow: hidden !important; text-overflow: ellipsis !important; }\n\n[data-gill-v16] .toc-sheet__actions--grid {\n  display: grid !important;\n  grid-template-columns: repeat(3, 1fr) !important;\n  gap: 8px !important;\n  padding: 12px 16px max(16px, env(safe-area-inset-bottom, 16px)) !important;\n  border-top: 1px solid var(--gb-border) !important;\n  background: color-mix(in srgb, var(--gb-surface) 96%, var(--gb-surface-muted)) !important;\n}\n[data-gill-v16] .toc-sheet__actions--grid .toc-action-btn {\n  display: inline-flex !important; align-items: center !important; justify-content: center !important; gap: 6px !important;\n  padding: 11px 4px !important;\n  border: none !important;\n  border-radius: 12px !important;\n  background: transparent !important;\n  font-family: var(--gb-font-sans) !important;\n  font-size: 13px !important; font-weight: 600 !important;\n  color: var(--gb-text-muted) !important;\n  transition: all .2s ease !important;\n  width: 100% !important; min-width: 0 !important;\n  cursor: pointer !important;\n}\n[data-gill-v16] .toc-sheet__actions--grid .toc-action-btn:hover {\n  background: var(--gb-surface-muted) !important;\n  color: var(--gb-text) !important;\n}\n[data-gill-v16] .toc-sheet__actions--grid .toc-action-btn.gb-save {\n  color: var(--gb-accent-gold-deep) !important;\n  background: color-mix(in srgb, var(--gb-accent-gold) 12%, transparent) !important;\n}\nhtml.dark [data-gill-v16] .toc-sheet__actions--grid .toc-action-btn.gb-save {\n  color: #eed093 !important;\n  background: rgba(245, 197, 66, 0.12) !important;\n}\n[data-gill-v16] .toc-sheet__actions--grid .toc-action-btn.gb-save.is-saved {\n  background: var(--gb-accent-gold) !important;\n  color: #fff !important;\n}\nhtml.dark [data-gill-v16] .toc-sheet__actions--grid .toc-action-btn.gb-save.is-saved {\n  background: #f5c542 !important;\n  color: #1a1a1a !important;\n}\n[data-gill-v16] .toc-sheet__actions--grid .toc-action-btn svg {\n  width: 16px !important; height: 16px !important; stroke: currentColor !important; fill: none !important; stroke-width: 1.8 !important; flex-shrink: 0 !important;\n}\n\n/* ============================================================\n   v16 FINAL LUXURY POLISH (Deep Card Shadows, Classic Roman Numeral Relief & Smooth Bounce)\n   ============================================================ */\n[data-gill-v16] .toc-sheet__list {\n  padding: 8px 10px !important;\n}\n[data-gill-v16] .toc-item, .toc-part-item {\n  border-radius: 16px !important;\n  margin: 4px 6px !important;\n  border-left: none !important;\n  border: 1px solid transparent !important;\n  transition: all .28s var(--gb-ease-out), transform .35s var(--gb-ease-spring) !important;\n}\n[data-gill-v16] .toc-item:hover, .toc-part-item:hover {\n  background: var(--gb-surface) !important;\n  border-color: var(--gb-border) !important;\n  box-shadow: 0 8px 24px rgba(0,0,0,.06), 0 2px 6px rgba(184,147,106,.12) !important;\n  transform: none !important;\n}\nhtml.dark [data-gill-v16] .toc-item:hover, html.dark .toc-part-item:hover {\n  background: rgba(255,255,255,.05) !important;\n  border-color: rgba(255,255,255,.1) !important;\n  box-shadow: 0 12px 34px rgba(0,0,0,.5), 0 0 18px rgba(245,197,66,.2) !important;\n}\n[data-gill-v16] .toc-item.is-current, .toc-part-item.is-current {\n  background: color-mix(in srgb, var(--gb-accent-gold) 12%, var(--gb-surface)) !important;\n  border-color: color-mix(in srgb, var(--gb-accent-gold) 40%, transparent) !important;\n  box-shadow: 0 6px 20px rgba(184,147,106,.18) !important;\n}\nhtml.dark [data-gill-v16] .toc-item.is-current, html.dark .toc-part-item.is-current {\n  background: rgba(245,197,66,.12) !important;\n  border-color: rgba(245,197,66,.35) !important;\n  box-shadow: 0 8px 24px rgba(0,0,0,.6), 0 0 22px rgba(245,197,66,.25) !important;\n}\n\n[data-gill-v16] .toc-item__num, .toc-part-item__num {\n  font-family: var(--gb-font-serif-display) !important;\n  font-style: normal !important;\n  font-weight: 800 !important;\n  color: var(--gb-accent-gold) !important;\n  text-shadow: 0 1px 1px rgba(255,255,255,.9), 0 2px 5px rgba(0,0,0,.18) !important;\n  transition: all .32s var(--gb-ease-spring) !important;\n}\nhtml.dark [data-gill-v16] .toc-item__num, html.dark .toc-part-item__num {\n  color: #eed093 !important;\n  text-shadow: 0 1px 2px rgba(0,0,0,.9), 0 0 14px rgba(245,197,66,.45) !important;\n}\n[data-gill-v16] .toc-item:hover .toc-item__num, .toc-part-item:hover .toc-part-item__num {\n  transform: scale(1.18) !important;\n  color: var(--gb-accent-gold-bright) !important;\n}\nhtml.dark [data-gill-v16] .toc-item:hover .toc-item__num, html.dark .toc-part-item:hover .toc-part-item__num {\n  color: #ffd18b !important;\n  text-shadow: 0 0 18px rgba(245,197,66,.85) !important;\n}\n\n/* ============================================================\n   v16 OWNER DESIGN SURGICAL FIXES (Closing All Bugs In Good Design)\n   ============================================================ */\n\n/* 1. Сетка шапки попапа без наложения стрелки ← */\n[data-gill-v16] .toc-sheet__head:has(.back) {\n  display: grid !important;\n  grid-template-columns: 34px 1fr !important;\n  gap: 12px !important;\n  align-items: center !important;\n  padding: 14px 22px 12px !important;\n}\n[data-gill-v16] .toc-sheet__head .back {\n  position: static !important;\n  width: 34px !important; height: 34px !important;\n  border-radius: 8px !important;\n  display: grid !important; place-items: center !important;\n  margin: 0 !important; padding: 0 !important;\n}\n\n/* 2. Устранение дрожания карточек (Jitter) */\n[data-gill-v16] .toc-item, .toc-part-item {\n  transform: none !important;\n}\n[data-gill-v16] .toc-item:hover, .toc-part-item:hover {\n  transform: none !important;\n}\n\n/* 3. Надёжный типографский цвет цифр без коричневых «кирпичей» */\n[data-gill-v16] .toc-item__num, .toc-part-item__num {\n  background: transparent !important;\n  color: #8a6538 !important;\n  text-shadow: 0 1px 0 rgba(255,255,255,1), 0 2px 4px rgba(0,0,0,.14) !important;\n}\n[data-gill-v16] .toc-item.is-current .toc-item__num, .toc-part-item.is-current .toc-part-item__num {\n  color: #6a4720 !important;\n}\nhtml.dark [data-gill-v16] .toc-item__num, html.dark .toc-part-item__num {\n  color: #e8b878 !important;\n  text-shadow: 0 1px 2px rgba(0,0,0,.9), 0 0 12px rgba(232,184,120,.45) !important;\n}\nhtml.dark [data-gill-v16] .toc-item.is-current .toc-item__num, html.dark .toc-part-item.is-current .toc-part-item__num {\n  color: #eed093 !important;\n  text-shadow: 0 1px 2px rgba(0,0,0,.9), 0 0 14px rgba(216,176,104,.45) !important;\n}\n\n/* 4. Яркий сияющий PLAY и треки в ночной теме */\nhtml.dark [data-gill-v16] .gb-ember {\n  --ring-color: #eed093 !important;\n  color: #eed093 !important;\n  box-shadow: 0 0 14px rgba(216, 176, 104, 0.22) !important;\n}\n\n/* 5. Усмирённый масштаб Лупы в кластере */\n\n/* 6. Оверлей на мобилках занимает всю ширину без слипания кнопок */\n@media (max-width: 640px) {\n[data-gill-v16] .toc-overlay {\n    padding: 0 !important;\n    align-items: flex-end !important;\n  }\n[data-gill-v16] .toc-sheet {\n    width: 100% !important;\n    max-height: 85vh;\n    border-radius: 22px 22px 0 0;\n    border-left: none; border-right: none; border-bottom: none;\n  }\n[data-gill-v16] .toc-sheet__actions {\n    padding: 12px 16px max(14px, env(safe-area-inset-bottom, 14px)) !important;\n    gap: 6px !important;\n  }\n[data-gill-v16] .toc-action-btn {\n    padding: 9px 12px !important; font-size: 13px !important;\n  }\n[data-gill-v16] .toc-action-btn.gb-save {\n    flex: 1 1 auto !important; justify-content: center !important;\n  }\n}\n@media (max-width: 420px) {\n[data-gill-v16] .toc-sheet__actions .toc-action-btn--ghost .btn-lbl {\n    display: none !important;\n  }\n[data-gill-v16] .toc-sheet__actions .toc-action-btn--ghost {\n    padding: 9px !important; width: 38px !important; min-width: 38px !important; justify-content: center !important;\n  }\n}\n\n[data-gill-v16] .toc-item.is-done { opacity: .82; }\n[data-gill-v16] .toc-item.is-done .toc-item__num { color: var(--gb-text-muted) !important; text-shadow: none !important; }\nhtml.dark [data-gill-v16] .toc-item.is-done .toc-item__num { color: #8b949e !important; text-shadow: none !important; }\n\n\n/* ============================================================\n   v16 PURITAN ANTIQUE BRASS LUXURY & NO TEXT TIPS\n   ============================================================ */\n\n/* 1. Отключение текстовых тултипов при наведении */\n[data-tip]::after {\n  display: none !important;\n  content: none !important;\n}\n\n/* 2. Монументальные карточки оглавления с античным матовым свечением (БЕЗ неоновой желтизны и дрожания) */\n[data-gill-v16] .toc-item, .toc-part-item {\n  border-radius: 16px !important;\n  transition: all .25s var(--gb-ease-out) !important;\n  border: 1px solid transparent !important;\n  position: relative !important;\n  overflow: hidden !important;\n  transform: none !important;\n}\n[data-gill-v16] .toc-item::before, .toc-part-item::before {\n  content: \"\" !important;\n  position: absolute !important;\n  top: 0 !important; left: 12% !important; right: 12% !important;\n  height: 1px !important;\n  background: linear-gradient(90deg, transparent, rgba(255,255,255,.85), transparent) !important;\n  opacity: .6 !important;\n  pointer-events: none !important;\n}\nhtml.dark [data-gill-v16] .toc-item::before, html.dark .toc-part-item::before {\n  background: linear-gradient(90deg, transparent, rgba(255,255,255,.09), transparent) !important;\n  opacity: 1 !important;\n}\n\n[data-gill-v16] .toc-item:hover, .toc-part-item:hover {\n  transform: none !important;\n  background: var(--gb-surface) !important;\n  border-color: var(--gb-border) !important;\n  box-shadow: 0 8px 24px rgba(0,0,0,.05), 0 2px 6px rgba(184,147,106,.08) !important;\n}\nhtml.dark [data-gill-v16] .toc-item:hover, html.dark .toc-part-item:hover {\n  background: rgba(255,255,255,.035) !important;\n  border-color: rgba(255,255,255,.07) !important;\n  box-shadow: 0 10px 30px rgba(0,0,0,.5), 0 0 16px rgba(216,176,104,.1) !important;\n}\n\n[data-gill-v16] .toc-item.is-current, .toc-part-item.is-current {\n  background: rgba(246, 241, 233, 0.98) !important;\n  border-color: rgba(184, 147, 106, 0.38) !important;\n  box-shadow: 0 6px 18px rgba(138,101,56,.1) !important;\n}\nhtml.dark [data-gill-v16] .toc-item.is-current, html.dark .toc-part-item.is-current {\n  background: rgba(216, 176, 104, 0.075) !important; /* Благородная матовая латунь изнутри */\n  border-color: rgba(216, 176, 104, 0.28) !important; /* Тонкий спокойный кант */\n  box-shadow: 0 8px 24px rgba(0,0,0,.65), 0 0 18px rgba(216, 176, 104, 0.12) !important; /* Мягкий благородный свет без неоновой кислоты */\n}\n\n/* 3. Античная типографика римских цифр */\n[data-gill-v16] .toc-item__num, .toc-part-item__num {\n  transition: transform .32s var(--gb-ease-spring), color .25s ease !important;\n  color: #8a6538 !important;\n}\nhtml.dark [data-gill-v16] .toc-item__num, html.dark .toc-part-item__num {\n  color: #d8b068 !important; /* Матовое античное золото */\n  text-shadow: 0 1px 2px rgba(0,0,0,.9), 0 0 10px rgba(216, 176, 104, 0.28) !important;\n}\nhtml.dark [data-gill-v16] .toc-item.is-current .toc-item__num, html.dark .toc-part-item.is-current .toc-part-item__num {\n  color: #eed093 !important; /* Тёплый светлый пергаментный блеск */\n  text-shadow: 0 1px 2px rgba(0,0,0,.9), 0 0 14px rgba(216, 176, 104, 0.45) !important;\n}\n\n[data-gill-v16] .toc-item:hover .toc-item__num, .toc-part-item:hover .toc-part-item__num {\n  transform: scale(1.15) !important;\n  color: #a87e4b !important;\n}\nhtml.dark [data-gill-v16] .toc-item:hover .toc-item__num, html.dark .toc-part-item:hover .toc-part-item__num {\n  color: #f5dcaa !important;\n  text-shadow: 0 0 16px rgba(216, 176, 104, 0.6) !important;\n}\n\n[data-gill-v16] .toc-item__chevron {\n  transition: transform .25s var(--gb-ease-spring), color .2s ease !important;\n}\n[data-gill-v16] .toc-item:hover .toc-item__chevron {\n  transform: translateX(3px) !important;\n  color: var(--gb-accent) !important;\n}\n\n/* ============================================================\n   v16 FINAL SILKY APPLE SMOOTHNESS & NOURISHED NIGHT PROGRESS\n   ============================================================ */\n\n/* 1. Ночные полоски прогресса без кислотной желтизны */\nhtml.dark [data-gill-v16] .mobile-btoc-progress-fill,\nhtml.dark [data-gill-v16] .toc-part-item__progress i,\nhtml.dark [data-gill-v16] .toc-part-item.is-current .toc-part-item__progress i {\n  background: linear-gradient(90deg, #eed093, #c59b58) !important; /* Тёплый светлый пергамент → античная английская латунь */\n  box-shadow: 0 0 8px rgba(216, 176, 104, 0.35) !important;\n}\nhtml.dark [data-gill-v16] .mobile-btoc-progress-track,\nhtml.dark [data-gill-v16] .toc-part-item__progress {\n  background: rgba(216, 176, 104, 0.15) !important;\n}\n\n/* 2. Плавнейшие анимации вместо резких скачков */\n[data-gill-v16] .toc-sheet {\n  transition: transform .38s cubic-bezier(.16, 1, .3, 1), background-color .3s ease !important;\n}\n[data-gill-v16] .toc-overlay {\n  transition: opacity .32s cubic-bezier(.2, .7, .2, 1) !important;\n}\n[data-gill-v16] .toc-item, .toc-part-item, .toc-action-btn, .gb-icon, .gb-ember, .gb-save {\n  transition: all .3s cubic-bezier(.2, .7, .2, 1) !important;\n}\n\n/* =========================================================\n   Standalone article floater — position matching legacy .theme-toggle\n\n/* =========================================================\n   Play Ember — Luxury Speed Expand\n   Premium morphing panel: ember widens into a floating pill,\n   speed buttons cascade in with staggered delays,\n   selection triggers a pulse + collapse.\n   ========================================================= */\n\n/* =========================================================\n   Speed Pill — horizontal morph from Play circle\n   Design: pill expands LEFT from ember, Play stays right.\n   Standalone: pill beside ember in .gb-floater\n   GBS rail: pill expands UP with blur (no horizontal space)\n   ========================================================= */\n\n/* Wrapper: positions pill relative to ember */\n.gb-ember-wrap {\n  position: relative;\n  display: inline-flex;\n  align-items: center;\n}\n\n/* Pill container — expands LEFT from ember circle */\n.gb-ember-expand {\n  position: absolute;\n  right: 0;\n  top: 50%;\n  transform: translateY(-50%) translateX(var(--gb-ember-shift, 0px));\n  display: flex;\n  align-items: center;\n  gap: 3px;\n  padding: 10px 48px 10px 14px; /* right padding = ember overlap */\n  border-radius: 999px; /* full pill — spec match */\n  background: color-mix(in srgb, var(--color-surface, #fff) 96%, transparent);\n  border: 1.5px solid color-mix(in srgb, var(--color-accent-gold, #b8936a) 30%, var(--color-border, #e5e2dc));\n  box-shadow:\n    0 4px 20px rgba(184, 147, 106, .10),\n    0 8px 32px rgba(0, 0, 0, .06),\n    inset 0 1px 0 rgba(255, 255, 255, .8);\n  -webkit-backdrop-filter: blur(20px) saturate(180%);\n  backdrop-filter: blur(20px) saturate(180%);\n  opacity: 0;\n  pointer-events: none;\n  /* Morph: start as circle at right edge, expand left */\n  clip-path: circle(20px at calc(100% - 24px) 50%);\n  transition:\n    clip-path .26s cubic-bezier(.2, .8, .2, 1),\n    opacity .22s ease,\n    box-shadow .3s ease;\n  /* z-index: 0 (was -1). Negative stacking hid the panel under page\n     surfaces on Safari/WebKit and broke hover/click capture on the\n     first interaction. Closed-state visibility is controlled by\n     opacity:0 + pointer-events:none, not stacking. */\n  z-index: 0;\n  white-space: nowrap;\n}\nhtml.dark .gb-ember-expand {\n  background: color-mix(in srgb, var(--color-surface, #161a21) 94%, transparent);\n  border-color: color-mix(in srgb, var(--color-accent-gold, #b8936a) 22%, rgba(255,255,255,.08));\n  box-shadow:\n    0 4px 24px rgba(216, 176, 104, .08),\n    0 12px 40px rgba(0, 0, 0, .35),\n    inset 0 1px 0 rgba(255, 255, 255, .05);\n}\n\n/* Open state — full pill revealed */\n.gb-ember-expand.is-open {\n  opacity: 1;\n  pointer-events: auto;\n  clip-path: inset(0 0 0 0 round 999px);\n  z-index: 1;\n  box-shadow:\n    0 6px 28px rgba(184, 147, 106, .14),\n    0 12px 40px rgba(0, 0, 0, .07),\n    inset 0 1px 0 rgba(255, 255, 255, .8);\n}\nhtml.dark .gb-ember-expand.is-open {\n  box-shadow:\n    0 6px 28px rgba(216, 176, 104, .12),\n    0 16px 48px rgba(0, 0, 0, .4),\n    inset 0 1px 0 rgba(255, 255, 255, .05);\n}\n\n/* ── Premium HOVER reveal (owner spec) ───────────────────────────────────\n   Desktop: the speed pill blooms out of the Play circle on HOVER, not click —\n   smooth, rubbery, deep. JS adds .is-open too, but this CSS makes the reveal\n   instant-feeling and resilient even before JS hydration. Touch (no hover)\n   ignores this and uses tap (JS). */\n@media (hover: hover) and (pointer: fine) {\n  .gb-ember-wrap:hover > .gb-ember-expand,\n  .gb-ember-wrap:focus-within > .gb-ember-expand {\n    opacity: 1;\n    pointer-events: auto;\n    clip-path: inset(0 0 0 0 round 999px);\n    z-index: 1;\n    box-shadow:\n      0 6px 28px rgba(184, 147, 106, .14),\n      0 12px 40px rgba(0, 0, 0, .07),\n      inset 0 1px 0 rgba(255, 255, 255, .8);\n  }\n  .gb-ember-wrap:hover > .gb-ember-expand::before,\n  .gb-ember-wrap:focus-within > .gb-ember-expand::before { opacity: 1; }\n  /* Cascade speed buttons on hover (mirror of .is-open cascade). Keep the\n     25ms premium stagger even if hover CSS opens before JS adds .is-open. */\n  .gb-ember-wrap:hover > .gb-ember-expand .gb-ember-expand__btn,\n  .gb-ember-wrap:focus-within > .gb-ember-expand .gb-ember-expand__btn {\n    opacity: 1;\n    transform: none;\n  }\n  .gb-ember-wrap:hover > .gb-ember-expand .gb-ember-expand__btn:nth-child(1),\n  .gb-ember-wrap:focus-within > .gb-ember-expand .gb-ember-expand__btn:nth-child(1) { transition-delay:.025s,.025s,0s,0s,0s; }\n  .gb-ember-wrap:hover > .gb-ember-expand .gb-ember-expand__btn:nth-child(2),\n  .gb-ember-wrap:focus-within > .gb-ember-expand .gb-ember-expand__btn:nth-child(2) { transition-delay:.05s,.05s,0s,0s,0s; }\n  .gb-ember-wrap:hover > .gb-ember-expand .gb-ember-expand__btn:nth-child(3),\n  .gb-ember-wrap:focus-within > .gb-ember-expand .gb-ember-expand__btn:nth-child(3) { transition-delay:.075s,.075s,0s,0s,0s; }\n  .gb-ember-wrap:hover > .gb-ember-expand .gb-ember-expand__btn:nth-child(4),\n  .gb-ember-wrap:focus-within > .gb-ember-expand .gb-ember-expand__btn:nth-child(4) { transition-delay:.10s,.10s,0s,0s,0s; }\n  .gb-ember-wrap:hover > .gb-ember-expand .gb-ember-expand__btn:nth-child(5),\n  .gb-ember-wrap:focus-within > .gb-ember-expand .gb-ember-expand__btn:nth-child(5) { transition-delay:.125s,.125s,0s,0s,0s; }\n  .gb-ember-wrap:hover > .gb-ember-expand .gb-ember-expand__btn:nth-child(6),\n  .gb-ember-wrap:focus-within > .gb-ember-expand .gb-ember-expand__btn:nth-child(6) { transition-delay:.15s,.15s,0s,0s,0s; }\n  /* Play circle drifts slightly to the RIGHT as the pill blooms from it\n     (single-article reference geometry — Play \"comes out of the circle\").\n     ONLY on single-article clusters: in GBS/Gill rails the pill opens UP,\n     so the Play button must NOT drift sideways there. */\n  .gb-ember-wrap:hover > .gb-ember,\n  .gb-ember-wrap:focus-within > .gb-ember {\n    transform: translateX(4px) scale(1.04);\n  }\n  [data-gill-v16] .gb-ember-wrap:hover > .gb-ember,\n  [data-gill-v16] .gb-ember-wrap:focus-within > .gb-ember,\n  .gbs-rail-foot .gb-ember-wrap:hover > .gb-ember,\n  .gbs-rail-foot .gb-ember-wrap:focus-within > .gb-ember {\n    transform: scale(1.06); /* gentle lift only — pill blooms UPWARD */\n  }\n}\n/* Deeper rubbery morph timing for the bloom */\n.gb-ember-expand {\n  transition:\n    clip-path .42s cubic-bezier(.16, 1.08, .3, 1),\n    opacity .26s ease,\n    box-shadow .34s ease;\n}\n.gb-ember {\n  transition: transform .42s cubic-bezier(.34, 1.56, .64, 1), color .2s ease;\n}\n\n/* Shimmer line */\n.gb-ember-expand::before {\n  content: '';\n  position: absolute;\n  top: 0; left: 8%; right: 8%;\n  height: 1px;\n  background: linear-gradient(90deg, transparent, rgba(184, 147, 106, .2), transparent);\n  opacity: 0;\n  transition: opacity .25s ease .12s;\n}\n.gb-ember-expand.is-open::before { opacity: 1; }\nhtml.dark .gb-ember-expand::before {\n  background: linear-gradient(90deg, transparent, rgba(216, 176, 104, .15), transparent);\n}\n\n/* Speed buttons — staggered cascade from left */\n.gb-ember-expand__btn {\n  display: grid;\n  place-items: center;\n  min-width: 40px;\n  height: 32px;\n  padding: 0 8px;\n  border: 1.5px solid color-mix(in srgb, var(--color-border, #e5e2dc) 70%, transparent);\n  border-radius: 12px;\n  background: transparent;\n  font-family: var(--f-ui, 'Source Sans 3', system-ui, sans-serif);\n  font-size: 12.5px;\n  font-weight: 700;\n  color: var(--color-text-muted, #6a6a6a);\n  cursor: pointer;\n  opacity: 0;\n  transform: translateX(12px) scale(.85);\n  transition:\n    opacity .2s ease,\n    transform .28s cubic-bezier(.34, 1.56, .64, 1),\n    background .18s ease,\n    color .18s ease,\n    border-color .18s ease;\n  -webkit-tap-highlight-color: transparent;\n}\n/* Cascade: each button slides in from right, staggered */\n.gb-ember-expand.is-open .gb-ember-expand__btn:nth-child(1) { opacity:1; transform:none; transition-delay:.025s,.025s,0s,0s,0s; }\n.gb-ember-expand.is-open .gb-ember-expand__btn:nth-child(2) { opacity:1; transform:none; transition-delay:.05s,.05s,0s,0s,0s; }\n.gb-ember-expand.is-open .gb-ember-expand__btn:nth-child(3) { opacity:1; transform:none; transition-delay:.075s,.075s,0s,0s,0s; }\n.gb-ember-expand.is-open .gb-ember-expand__btn:nth-child(4) { opacity:1; transform:none; transition-delay:.10s,.10s,0s,0s,0s; }\n.gb-ember-expand.is-open .gb-ember-expand__btn:nth-child(5) { opacity:1; transform:none; transition-delay:.125s,.125s,0s,0s,0s; }\n.gb-ember-expand.is-open .gb-ember-expand__btn:nth-child(6) { opacity:1; transform:none; transition-delay:.15s,.15s,0s,0s,0s; }\n\n/* Hover */\n@media (hover: hover) and (pointer: fine) {\n  .gb-ember-expand__btn:hover {\n    background: color-mix(in srgb, var(--color-accent-gold, #b8936a) 10%, transparent);\n    border-color: color-mix(in srgb, var(--color-accent-gold, #b8936a) 40%, transparent);\n    color: var(--color-text, #1a1a1a);\n  }\n  html.dark .gb-ember-expand__btn:hover {\n    background: rgba(216, 176, 104, .08);\n    border-color: rgba(216, 176, 104, .25);\n    color: var(--color-accent-gold-bright, #f0c896);\n  }\n}\n.gb-ember-expand__btn:active { transform: scale(.92); transition-duration: .06s; }\n\n/* Active speed — gold fill */\n.gb-ember-expand__btn.is-active {\n  background: linear-gradient(135deg, var(--color-accent-gold, #b8936a), var(--color-accent-gold-bright, #d8aa6d));\n  border-color: transparent;\n  color: #fff;\n  font-weight: 800;\n  box-shadow: 0 2px 8px rgba(184, 147, 106, .2);\n}\nhtml.dark .gb-ember-expand__btn.is-active {\n  background: linear-gradient(135deg, var(--color-accent-gold, #b8936a), #eed093);\n  color: #0e1116;\n  box-shadow: 0 2px 12px rgba(216, 176, 104, .2);\n}\n\n/* Ember glow when panel open */\n/* Play circle stays put when pill opens — matches reference HTML */\n.gb-ember-wrap .gb-ember[aria-expanded=\"true\"] {\n  z-index: 2;\n}\n\n/* === GBS Rail: pill expands UP (no horizontal space) === */\n[data-gill-v16] .gb-ember-expand,\n.gbs-rail-foot .gb-ember-expand {\n  right: auto;\n  left: 50%;\n  top: auto;\n  bottom: calc(100% + 8px);\n  transform: translateX(calc(-50% + var(--gb-ember-shift, 0px)));\n  padding: 5px 8px;\n  clip-path: circle(16px at 50% calc(100% - 16px));\n}\n[data-gill-v16] .gb-ember-expand.is-open,\n.gbs-rail-foot .gb-ember-expand.is-open {\n  clip-path: inset(0 0 0 0 round 999px);\n}\n\n\n/* === Mobile: pill above ember with blur backdrop (no side space) ===\n   Per owner spec 2026-06-26: на mobile нет горизонтального места\n   для morph LEFT, поэтому открываем строго ВВЕРХ с blur-фоном.\n   max-width = viewport-8px с обеих сторон гарантирует, что pill\n   не вылезет за край на 320–390px устройствах. */\n@media (max-width: 899px) {\n  .gb-ember-expand {\n    right: auto;\n    left: 50%;\n    top: auto;\n    bottom: calc(100% + 10px);\n    transform: translateX(calc(-50% + var(--gb-ember-shift, 0px)));\n    padding: 5px 8px;\n    /* viewport-safe ширина: не больше 92vw минус 16px safe-area */\n    max-width: min(92vw, calc(100vw - 32px));\n    clip-path: circle(16px at 50% calc(100% - 16px));\n    /* усиленный blur — pill парит над текстом, не упирается в anchor */\n    -webkit-backdrop-filter: blur(24px) saturate(180%);\n    backdrop-filter: blur(24px) saturate(180%);\n  }\n  .gb-ember-expand.is-open {\n    clip-path: inset(0 0 0 0 round 999px);\n  }\n\n  /* Компактнее кнопки чтобы 6 скоростей помещались на 320px */\n  .gb-ember-expand__btn {\n    min-width: 36px;\n    height: 30px;\n    padding: 0 6px;\n    font-size: 12px;\n  }\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .gb-ember-expand, .gb-ember-expand__btn {\n    transition-duration: 0.01ms !important;\n  }\n}\n\n/* =========================================================\n   Favorites Block — homepage \"Ваше избранное\" section\n   Rendered from localStorage gb-favorites by inline script.\n   ========================================================= */\n.favorites-block {\n  margin: 28px 0 40px;\n}\n.favorites-block__heading {\n  margin: 0 0 6px;\n  font-family: var(--f-body, Lora, Georgia, serif);\n  font-size: 20px;\n  font-weight: 700;\n  color: var(--color-text, #1a1a1a);\n}\n.favorites-block__sub {\n  margin: 0 0 16px;\n  font-family: var(--f-ui, 'Source Sans 3', system-ui, sans-serif);\n  font-size: 13px;\n  color: var(--color-text-muted, #6a6a6a);\n}\n.favorites-list {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));\n  gap: 14px;\n}\n.favorites-card {\n  display: flex;\n  flex-direction: column;\n  text-decoration: none;\n  background: var(--color-surface, #fff);\n  border: 1px solid var(--color-border, #e5e2dc);\n  border-radius: 14px;\n  overflow: hidden;\n  transition:\n    border-color .25s ease,\n    box-shadow .35s cubic-bezier(.2,.7,.2,1),\n    transform .35s cubic-bezier(.2,.7,.2,1);\n}\n.favorites-card:hover {\n  border-color: var(--color-accent, #7a2e2e);\n  box-shadow: 0 8px 24px rgba(0,0,0,.08);\n  transform: translateY(-3px);\n  text-decoration: none;\n}\nhtml.dark .favorites-card {\n  background: var(--color-surface, #161a21);\n  border-color: var(--color-border, #232830);\n}\nhtml.dark .favorites-card:hover {\n  border-color: var(--color-accent, #d4a574);\n  box-shadow: 0 12px 32px rgba(0,0,0,.3);\n}\n.favorites-card__img {\n  height: 140px;\n  background-size: cover;\n  background-position: center;\n  background-color: var(--color-surface-muted, #f4f2ed);\n}\n.favorites-card__body {\n  padding: 14px 16px 16px;\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n}\n.favorites-card__section {\n  font-family: var(--f-ui, 'Source Sans 3', system-ui, sans-serif);\n  font-size: 10px;\n  font-weight: 700;\n  letter-spacing: .08em;\n  text-transform: uppercase;\n  color: var(--color-accent, #7a2e2e);\n}\n.favorites-card__title {\n  font-family: var(--f-body, Lora, Georgia, serif);\n  font-size: 15px;\n  font-weight: 700;\n  line-height: 1.3;\n  color: var(--color-text, #1a1a1a);\n}\n.favorites-card__desc {\n  font-family: var(--f-ui, 'Source Sans 3', system-ui, sans-serif);\n  font-size: 12px;\n  line-height: 1.5;\n  color: var(--color-text-muted, #6a6a6a);\n  display: -webkit-box;\n  -webkit-line-clamp: 2;\n  -webkit-box-orient: vertical;\n  overflow: hidden;\n}\n@media (max-width: 600px) {\n  .favorites-list {\n    grid-template-columns: 1fr;\n  }\n  .favorites-card__img {\n    height: 100px;\n  }\n}\n\n/* === Roman numeral chip (used in gbs2-bbar mobile) =====================\n   Unified naming: `gb-roman` (previously inconsistent fc-roman / gb-roman).\n   Style is editorial: serif italic, gold-tinted, slight letter-spacing.\n   Hidden in print and from screen readers (aria-hidden=\"true\" already set\n   by RomanNumeral.astro). */\n.gb-roman {\n  display: inline-block;\n  font-family: var(--gb-font-serif-display, 'Playfair Display', Georgia, \"Times New Roman\", serif);\n  font-style: italic;\n  font-weight: 700;\n  letter-spacing: 0.06em;\n  color: var(--color-accent-gold, #b8936a);\n  margin-right: 6px;\n  line-height: 1;\n}\nhtml.dark .gb-roman {\n  color: var(--color-accent-gold-bright, #d8aa6d);\n}\n@media print { .gb-roman { display: none; } }\n\n/* ============================================================\n   v16 LAYOUT + RESPONSIVE LAYER (GILL-F fix)\n   The v16 chrome uses .gbs-rail / .mobile-bottom-bar / .toc-overlay,\n   but the legacy .gbs2-world grid was built for .gbs2-rail (304px col).\n   This layer gives the v16 world its own desktop grid (rail + content)\n   and a proper mobile switch (hide rail, show fixed bottom bar, enable\n   the TOC overlay popups). Scoped to [data-gill-v16] so non-v16 pages\n   are untouched. Overlays/bottom-bar are nested inside the wrapper so\n   the existing [data-gill-v16] descendant rules apply.\n   ============================================================ */\n\n/* ---- Desktop: 2-column grid (rail + content) ---- */\n@media (min-width:64em){\n  .gbs2-world[data-gill-v16]{\n    display:grid;\n    grid-template-columns:240px minmax(0,1fr);\n    gap:clamp(20px,2.6vw,40px);\n    align-items:start;\n    min-height:auto;\n  }\n  .gbs2-world[data-gill-v16] > .gbs-rail{\n    grid-column:1;\n    position:sticky;top:16px;align-self:start;\n    max-height:calc(100vh - 32px);max-height:calc(100dvh - 32px);\n    overflow:auto;\n  }\n  .gbs2-world[data-gill-v16] > .page-wrap{\n    grid-column:2;width:min(820px,100%);\n  }\n  /* Bottom bar + overlays are desktop-hidden */\n  [data-gill-v16] .mobile-bottom-bar{display:none}\n}\n\n/* The legacy desktop body padding (304px) must not apply to v16 pages */\n@media (min-width:64em){\n  body.gbs-world:has(.gbs2-world[data-gill-v16]){padding-left:0}\n  body.gbs-world:has(.gbs2-world[data-gill-v16]) .gbs2-world[data-gill-v16]{\n    width:min(1180px,94vw);margin:0 auto;\n  }\n}\n\n/* ---- Mobile/tablet (<64em): hide rail, show fixed bottom bar ---- */\n@media (max-width:63.99em){\n  .gbs2-world[data-gill-v16]{display:block;min-height:0}\n  [data-gill-v16] .gbs-rail{display:none}\n  [data-gill-v16] .page-wrap{width:100%;padding-bottom:84px}\n  [data-gill-v16] .mobile-bottom-bar{\n    display:flex;\n    position:fixed;left:10px;right:10px;\n    bottom:calc(10px + env(safe-area-inset-bottom,0px));\n    top:auto;\n    z-index:var(--z-bottom-bar,400);\n  }\n}\n\n/* =========================================================\n   GILL-C SAFETY NET — roman numerals must NEVER inherit link blue.\n   If a built page is missing the [data-gill-v16] attr (build desync),\n   the scoped gold rules don't apply and the numerals fall back to\n   --color-link (#1f4ea3) blue. This unscoped fallback prevents that.\n   The scoped [data-gill-v16] rules still win when the attr is present.\n   ========================================================= */\n.gbs-rail-card__num,\n.toc-item__num,\n.toc-part-item__num {\n  color: var(--color-accent-gold, #b8936a);\n}\n","file":"/home/user/work/gb-is-my-strength/css/floating-cluster.css"}]},"stylelintType":"parseError"},{"type":"warning","text":"Cannot parse selector (Error: Expected a pseudo-class or pseudo-element.)","line":967,"column":4,"endLine":984,"endColumn":2,"node":{"raws":{"before":"\n   ","between":"","selector":{"raw":"v15: MOBILE PREVIEW — Save REMOVED from bottom-bar\n   Bottom-bar now has: TOC + section + dots + % + theme + search + play\n   ============================================================ */\n\n/* v15: bottom-bar WITHOUT Save (now in TOC popup) */\n[data-gill-v16] .mobile-bottom-bar","value":"v15: MOBILE PREVIEW — Save REMOVED from bottom-bar\n   Bottom-bar now has: TOC + section + dots + % + theme + search + play\n   ============================================================ */\n\n\n[data-gill-v16] .mobile-bottom-bar"},"semicolon":true,"after":"\n"},"type":"rule","nodes":[{"raws":{"before":"\n  ","between":":"},"type":"decl","source":{"end":{"column":20,"line":973,"offset":33002},"inputId":0,"start":{"column":3,"line":973,"offset":32984}},"prop":"position","value":"absolute"},{"raws":{"before":"","between":":"},"type":"decl","source":{"end":{"column":29,"line":973,"offset":33011},"inputId":0,"start":{"column":21,"line":973,"offset":33002}},"prop":"left","value":"6px"},{"raws":{"before":"","between":":"},"type":"decl","source":{"end":{"column":39,"line":973,"offset":33021},"inputId":0,"start":{"column":30,"line":973,"offset":33011}},"prop":"right","value":"6px"},{"raws":{"before":"","between":":"},"type":"decl","source":{"end":{"column":50,"line":973,"offset":33032},"inputId":0,"start":{"column":40,"line":973,"offset":33021}},"prop":"bottom","value":"6px"},{"raws":{"before":"\n  ","between":":"},"type":"decl","source":{"end":{"column":15,"line":974,"offset":33048},"inputId":0,"start":{"column":3,"line":974,"offset":33035}},"prop":"display","value":"flex"},{"raws":{"before":"","between":":"},"type":"decl","source":{"end":{"column":34,"line":974,"offset":33067},"inputId":0,"start":{"column":16,"line":974,"offset":33048}},"prop":"align-items","value":"center"},{"raws":{"before":"","between":":"},"type":"decl","source":{"end":{"column":64,"line":974,"offset":33097},"inputId":0,"start":{"column":35,"line":974,"offset":33067}},"prop":"justify-content","value":"space-between"},{"raws":{"before":"","between":":"},"type":"decl","source":{"end":{"column":72,"line":974,"offset":33105},"inputId":0,"start":{"column":65,"line":974,"offset":33097}},"prop":"gap","value":"4px"},{"raws":{"before":"\n  ","between":":"},"type":"decl","source":{"end":{"column":18,"line":975,"offset":33124},"inputId":0,"start":{"column":3,"line":975,"offset":33108}},"prop":"padding","value":"6px 8px"},{"raws":{"before":"","between":":"},"type":"decl","source":{"end":{"column":37,"line":975,"offset":33143},"inputId":0,"start":{"column":19,"line":975,"offset":33124}},"prop":"border-radius","value":"20px"},{"raws":{"before":"\n  ","between":":"},"type":"decl","source":{"end":{"column":35,"line":976,"offset":33179},"inputId":0,"start":{"column":3,"line":976,"offset":33146}},"prop":"background","value":"rgba(253,252,249,.96)"},{"raws":{"before":"\n  ","between":":"},"type":"decl","source":{"end":{"column":36,"line":977,"offset":33216},"inputId":0,"start":{"column":3,"line":977,"offset":33182}},"prop":"border","value":"1px solid var(--gb-border)"},{"raws":{"before":"\n  ","between":":"},"type":"decl","source":{"end":{"column":52,"line":978,"offset":33269},"inputId":0,"start":{"column":3,"line":978,"offset":33219}},"prop":"-webkit-backdrop-filter","value":"blur(14px) saturate(160%)"},{"raws":{"before":"\n  ","between":":"},"type":"decl","source":{"end":{"column":44,"line":979,"offset":33314},"inputId":0,"start":{"column":3,"line":979,"offset":33272}},"prop":"backdrop-filter","value":"blur(14px) saturate(160%)"},{"raws":{"before":"\n  ","between":":"},"type":"decl","source":{"end":{"column":40,"line":980,"offset":33355},"inputId":0,"start":{"column":3,"line":980,"offset":33317}},"prop":"box-shadow","value":"0 8px 24px rgba(0,0,0,.10)"},{"raws":{"before":"\n  ","between":":"},"type":"decl","source":{"end":{"column":34,"line":981,"offset":33390},"inputId":0,"start":{"column":3,"line":981,"offset":33358}},"prop":"font-family","value":"var(--gb-font-sans)"},{"raws":{"before":"","between":":"},"type":"decl","source":{"end":{"column":51,"line":981,"offset":33407},"inputId":0,"start":{"column":35,"line":981,"offset":33390}},"prop":"font-size","value":"11.5px"},{"raws":{"before":"\n  ","between":":"},"type":"decl","source":{"end":{"column":30,"line":982,"offset":33438},"inputId":0,"start":{"column":3,"line":982,"offset":33410}},"prop":"z-index","value":"var(--z-bottom-bar)"},{"raws":{"before":"\n  ","between":":"},"type":"decl","source":{"end":{"column":24,"line":983,"offset":33463},"inputId":0,"start":{"column":3,"line":983,"offset":33441}},"prop":"box-sizing","value":"border-box"}],"source":{"end":{"column":1,"line":984,"offset":33465},"inputId":0,"start":{"column":4,"line":967,"offset":32701}},"selector":"v15: MOBILE PREVIEW — Save REMOVED from bottom-bar\n   Bottom-bar now has: TOC + section + dots + % + theme + search + play\n   ============================================================ */\n\n\n[data-gill-v16] .mobile-bottom-bar","lastEach":10,"indexes":{},"inputs":[{"hasBOM":false,"css":"/* ===================================================================\n   floating-cluster.css — v16 Floating Cluster Component Styles\n   Источник истины: Astro-компоненты (src/components/ui/floating-cluster/)\n   Этот файл — единый CSS для legacy root HTML, где Astro build не применяется.\n   Авто-генерация: копия стилей из <style is:global> компонентов.\n\n   Канонические классы: gb-* (единая система, fc-* упразднены).\n   =================================================================== */\n\n@layer components {\n\n:root {\n  --gb-accent-strong: #d4af37;\n  --gb-ease-out: cubic-bezier(.2,.7,.2,1);\n  --gb-ease-spring: cubic-bezier(.34,1.56,.64,1);\n  --gb-accent: #d4af37;\n  --gb-font-serif-display: \"Lora\", serif;\n  --gb-accent-gold: #d4af37;\n  --gb-accent-gold-bright: #ffd700;\n  --gb-font-serif: \"Lora\", serif;\n  --gb-font-sans: \"Source Sans 3\", sans-serif;\n  --gb-border: rgba(255,255,255,0.15);\n  --gb-text: #fff;\n  --gb-text-muted: rgba(255,255,255,0.6);\n  --z-sheet: 1000;\n  --gb-surface: #1a1a1a;\n  --gb-ease-overshoot: cubic-bezier(.34,1.56,.64,1);\n  --gb-border-strong: rgba(255,255,255,0.25);\n  --gb-surface-muted: #2a2a2a;\n  --gb-ease-precise: cubic-bezier(.2,.7,.2,1);\n  --gb-text-faint: rgba(255,255,255,0.4);\n  --gb-accent-gold-deep: #b8860b;\n}\n\n/* =========================================================\n   gb-floater — standalone vertical cluster\n   (SingleArticleCluster.astro)\n   ========================================================= */\n.gb-floater {\n  position: fixed;\n  top: max(20px, env(safe-area-inset-top, 20px));\n  right: max(20px, env(safe-area-inset-right, 20px));\n  z-index: var(--z-toast, 9800);\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 6px;\n  pointer-events: none;\n}\n\n.gb-floater > * {\n  pointer-events: auto;\n}\n\n/* Play/Save in standalone floater: match reference HTML (transparent bg, 36px, no circle) */\n\n/* Hermeneutics variant: EXACT historical .theme-toggle position from css/site.css\n   Source of truth: .theme-toggle { position:absolute; top:calc(clamp(24px,3.5vw,44px)-4px); right:max(8.5vw,...) }\n   DO NOT invent calc formulas — use these exact values. */\n.gb-floater--hermeneutics {\n  top: calc(clamp(24px, 3.5vw, 44px) - 4px);\n  right: max(8.5vw, env(safe-area-inset-right, 0px));\n}\n@media (max-width: 899px) {\n  .gb-floater--hermeneutics {\n    /* On mobile the floater becomes horizontal pill at bottom (separate rule below),\n       but if it's still vertical, use the mobile theme-toggle position */\n    top: calc(clamp(24px, 3.5vw, 44px) - 4px);\n    right: max(4.5vw, env(safe-area-inset-right, 0px));\n  }\n}\n\n\n/* ---- GILL-A fix: prevent vertical text in gbs2-mobile-head on narrow screens ----\n   gbs2-mobile-title gets squeezed to 0 by 4 control buttons (4×38px+gaps=~170px).\n   Force title to truncate instead of stacking vertically per character. */\n.gbs2-mobile-title { overflow: hidden; }\n.gbs2-mobile-title b,\n.gbs2-mobile-title span {\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  max-width: 100%;\n}\n/* Mobile: standalone floater becomes horizontal pill at bottom */\n@media (max-width: 899px) {\n  .gb-floater {\n    top: auto;\n    left: 50%;\n    right: auto;\n    bottom: calc(12px + env(safe-area-inset-bottom, 0px));\n    transform: translateX(-50%);\n    flex-direction: row;\n    gap: 2px;\n    padding: 3px;\n    border: 1px solid color-mix(in srgb, var(--color-border, #e5e2dc) 86%, transparent);\n    border-radius: 24px;\n    background: color-mix(in srgb, var(--color-surface, #fff) 94%, transparent);\n    -webkit-backdrop-filter: blur(16px) saturate(160%);\n    backdrop-filter: blur(16px) saturate(160%);\n    z-index: var(--z-bottom-bar, 2000);\n  }\n  html.dark .gb-floater {\n    background: color-mix(in srgb, var(--color-surface, #161a21) 94%, transparent);\n    border-color: rgba(255, 255, 255, 0.08);\n  }\n  body.fc-single-active .article-main,\n  body.gb-cluster-single-active .article-main {\n    padding-bottom: 88px;\n  }\n}\n\n/* =========================================================\n   gb-icon — иконка с halo-кружком на hover (::before)\n   ========================================================= */\n.gb-icon {\n  --icon-stroke: 1.7;\n  width: 40px;\n  height: 40px;\n  display: grid;\n  place-items: center;\n  position: relative;\n  color: var(--color-text, #1a1a1a);\n  background: transparent;\n  border: 0;\n  border-radius: 50%;\n  transition:\n    color .28s var(--gb-ease-out, cubic-bezier(.2,.7,.2,1)),\n    transform .32s var(--gb-ease-spring, cubic-bezier(.34,1.56,.64,1));\n  cursor: pointer;\n  flex-shrink: 0;\n  transform-origin: center;\n}\n\n.gb-icon::before {\n  content: '';\n  position: absolute;\n  inset: 6px;\n  border-radius: 50%;\n  border: 1px solid var(--color-accent, #7a2e2e);\n  opacity: 0;\n  transform: scale(.7);\n  transition:\n    opacity .28s var(--gb-ease-out, cubic-bezier(.2,.7,.2,1)),\n    transform .32s var(--gb-ease-spring, cubic-bezier(.34,1.56,.64,1));\n  pointer-events: none;\n}\n\n@media (hover: hover) and (pointer: fine) {\n  .gb-icon:hover {\n    color: var(--color-accent, #7a2e2e);\n    transform: scale(1.12);\n  }\n  .gb-icon:hover::before {\n    opacity: 0.35;\n    transform: scale(1);\n  }\n  html.dark .gb-icon:hover {\n    color: var(--color-accent-strong, #e8b878);\n  }\n  .gb-icon:hover svg {\n    transform: scale(1.02);\n  }\n}\n\n.gb-icon:active {\n  transform: scale(.88);\n  transition: transform .12s cubic-bezier(.4,0,.2,1);\n}\n.gb-icon:active::before {\n  opacity: 0.5;\n  transform: scale(1);\n}\n.gb-icon:focus-visible {\n  outline: 2px solid var(--color-accent, #7a2e2e);\n  outline-offset: 4px;\n  border-radius: 50%;\n}\n\n.gb-icon svg {\n  width: 20px;\n  height: 20px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: var(--icon-stroke, 1.7);\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  transition:\n    transform .32s var(--gb-ease-spring, cubic-bezier(.34,1.56,.64,1)),\n    stroke-width .28s var(--gb-ease-out, cubic-bezier(.2,.7,.2,1));\n}\n\n/* =========================================================\n   gb-theme-toggle — морф солнца/луны (180° rotation)\n   ========================================================= */\n.gb-theme-toggle {\n  overflow: hidden;\n}\n\n.gb-theme-toggle .theme-icon-sun,\n.gb-theme-toggle .theme-icon-moon {\n  position: absolute;\n  inset: 0;\n  display: grid;\n  place-items: center;\n  transition:\n    opacity .32s var(--gb-ease-out, cubic-bezier(.2,.7,.2,1)),\n    transform .42s var(--gb-ease-spring, cubic-bezier(.34,1.56,.64,1));\n}\n\n.gb-theme-toggle .theme-icon-sun  { opacity: 1; transform: rotate(0) scale(1); }\n.gb-theme-toggle .theme-icon-moon { opacity: 0; transform: rotate(-90deg) scale(.5); }\n\nhtml.dark .gb-theme-toggle .theme-icon-sun  { opacity: 0; transform: rotate(90deg) scale(.5); }\nhtml.dark .gb-theme-toggle .theme-icon-moon { opacity: 1; transform: rotate(0) scale(1); }\n\n@media (hover: hover) and (pointer: fine) {\n  .gb-theme-toggle:hover { color: var(--color-accent, #7a2e2e); transform: scale(1.10); }\n}\n.gb-theme-toggle:active { transform: scale(.92); transition: transform .12s; }\n\n/* =========================================================\n   gb-ember — play/pause с SVG progress ring\n   (PlayEmber.astro — стили в SingleArticleCluster.astro)\n   ========================================================= */\n.gb-ember {\n  --p: 0;\n  --ember-size: 36px;\n  --ring-color: var(--color-accent, #7a2e2e);\n  appearance: none;\n  border: 0;\n  position: relative;\n  display: grid;\n  place-items: center;\n  isolation: isolate;\n  cursor: pointer;\n  color: var(--color-text, #1a1a1a);\n  width: var(--ember-size);\n  height: var(--ember-size);\n  border-radius: 50%;\n  background: transparent;\n  transition:\n    transform .32s var(--gb-ease-spring, cubic-bezier(.34,1.56,.64,1)),\n    color .28s var(--gb-ease-out, cubic-bezier(.2,.7,.2,1));\n  flex-shrink: 0;\n  transform-origin: center;\n}\n\n/* Halo ring */\n.gb-ember::before {\n  content: '';\n  position: absolute;\n  inset: 6px;\n  border-radius: 50%;\n  border: 1px solid var(--ring-color);\n  opacity: 0;\n  transform: scale(.7);\n  transition:\n    opacity .28s var(--gb-ease-out, cubic-bezier(.2,.7,.2,1)),\n    transform .32s var(--gb-ease-spring, cubic-bezier(.34,1.56,.64,1));\n  pointer-events: none;\n}\n\n@media (hover: hover) and (pointer: fine) {\n  .gb-ember:hover { transform: scale(1.12); }\n  .gb-ember:hover::before { opacity: 0.4; transform: scale(1); }\n}\n.gb-ember:active { transform: scale(.88); transition: transform .12s cubic-bezier(.4,0,.2,1); }\n.gb-ember:active::before { opacity: 0.55; transform: scale(1); }\n.gb-ember:focus-visible { outline: 2px solid var(--color-accent, #7a2e2e); outline-offset: 4px; border-radius: 50%; }\n.gb-ember:focus-visible::before { opacity: 0.55; transform: scale(1); }\n\n/* SVG progress ring */\n.gb-ember__ring-svg {\n  position: absolute;\n  inset: 0;\n  width: 100%;\n  height: 100%;\n  pointer-events: none;\n  overflow: visible;\n  opacity: 0;\n  transform: rotate(-90deg);\n  transform-origin: center;\n  transition: opacity .28s var(--gb-ease-out, cubic-bezier(.2,.7,.2,1));\n}\n.gb-ember[data-state=\"playing\"]  .gb-ember__ring-svg,\n.gb-ember[data-state=\"paused\"]   .gb-ember__ring-svg,\n.gb-ember[data-state=\"complete\"] .gb-ember__ring-svg { opacity: 1; }\n\n.gb-ember__ring-track {\n  fill: none;\n  stroke: var(--color-border, #e5e2dc);\n  stroke-width: 1.5;\n  opacity: 0.4;\n}\n.gb-ember__ring-progress {\n  fill: none;\n  stroke: var(--ring-color);\n  stroke-width: 1.5;\n  stroke-linecap: round;\n  stroke-dasharray: 283;\n  /* --p is a fraction 0..1 (set by TTS handler in floating-cluster-controller.js).\n     Legacy code expected percentage 0..100; controller now passes 0..1.\n     If a consumer still passes 0..100, clamp via min() keeps it safe. */\n  stroke-dashoffset: calc(283 - 283 * min(1, max(0, var(--p, 0))));\n  transition: stroke-dashoffset .42s cubic-bezier(.4,0,.2,1);\n}\n\n/* Иконки внутри ember */\n.gb-ember__glyph {\n  position: relative;\n  z-index: 2;\n  width: 14px;\n  height: 14px;\n  fill: currentColor;\n  transform: translateX(1px);\n}\n.gb-ember__pause {\n  position: relative;\n  z-index: 2;\n  width: 14px;\n  height: 14px;\n  display: none;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 2.2;\n  stroke-linecap: round;\n}\n.gb-ember__check {\n  display: none;\n  position: relative;\n  z-index: 2;\n  width: 14px;\n  height: 14px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 2.2;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n\n/* Показываем нужную иконку по data-state */\n.gb-ember[data-state=\"playing\"]  .gb-ember__glyph,\n.gb-ember[data-state=\"paused\"]   .gb-ember__glyph,\n.gb-ember[data-state=\"complete\"] .gb-ember__glyph { display: none; }\n\n.gb-ember[data-state=\"playing\"] .gb-ember__pause,\n.gb-ember[data-state=\"paused\"]  .gb-ember__pause  { display: block; }\n.gb-ember[data-state=\"complete\"] .gb-ember__check  { display: block; }\n\n/* Цвета по состоянию */\n.gb-ember[data-state=\"playing\"]  { color: var(--ring-color); }\n.gb-ember[data-state=\"paused\"]   { color: var(--ring-color); }\n.gb-ember[data-state=\"complete\"] { color: var(--color-accent-gold-bright, #d8aa6d); }\n\n/* Loading pulse */\n.gb-ember.is-loading::before {\n  animation: gb-ember-loading-pulse 1.4s ease-in-out infinite;\n}\n@keyframes gb-ember-loading-pulse {\n  0%, 100% { opacity: 0; }\n  50%      { opacity: 0.5; }\n}\n\n/* Dark mode glow */\nhtml.dark .gb-ember {\n  --ring-color: #eed093;\n  color: #eed093;\n  box-shadow: 0 0 14px rgba(216, 176, 104, 0.22);\n}\n\n/* =========================================================\n   gb-save — bookmark (без halo ::before)\n   (SaveButton.astro)\n   ========================================================= */\n.gb-save {\n  width: 40px;\n  height: 40px;\n  display: grid;\n  place-items: center;\n  position: relative;\n  color: var(--color-text, #1a1a1a);\n  background: transparent;\n  border: 0;\n  border-radius: 50%;\n  transition:\n    color .28s var(--gb-ease-out, cubic-bezier(.2,.7,.2,1)),\n    transform .32s var(--gb-ease-spring, cubic-bezier(.34,1.56,.64,1));\n  cursor: pointer;\n  flex-shrink: 0;\n  transform-origin: center;\n}\n\n@media (hover: hover) and (pointer: fine) {\n  .gb-save:hover {\n    color: var(--color-accent-gold, #b8936a);\n    transform: scale(1.10);\n  }\n  html.dark .gb-save:hover {\n    color: var(--color-accent-strong, #e8b878);\n  }\n}\n.gb-save:active { transform: scale(.88); transition: transform .12s cubic-bezier(.4,0,.2,1); }\n.gb-save:focus-visible { outline: 2px solid var(--color-accent, #7a2e2e); outline-offset: 4px; border-radius: 50%; }\n\n.gb-save.is-saved { color: var(--color-accent-gold-bright, #d8aa6d); }\n.gb-save.is-saved svg {\n  fill: var(--color-accent-gold, #b8936a);\n  stroke: var(--color-accent-gold, #b8936a);\n  animation: gb-save-bounce .5s var(--gb-ease-spring, cubic-bezier(.34,1.56,.64,1));\n}\n@keyframes gb-save-bounce {\n  0%   { transform: scale(1); }\n  40%  { transform: scale(1.30); }\n  70%  { transform: scale(.92); }\n  100% { transform: scale(1); }\n}\n\n.gb-save svg {\n  width: 20px;\n  height: 20px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 1.7;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  transition:\n    transform .32s var(--gb-ease-spring, cubic-bezier(.34,1.56,.64,1)),\n    fill .28s var(--gb-ease-out, cubic-bezier(.2,.7,.2,1)),\n    stroke .28s var(--gb-ease-out, cubic-bezier(.2,.7,.2,1));\n}\n\n/* =========================================================\n   gb-toast — уведомление (используется floating-cluster-controller.js)\n   ========================================================= */\n.gb-fc-toast {\n  position: fixed;\n  left: 50%;\n  bottom: max(28px, env(safe-area-inset-bottom, 28px));\n  transform: translateX(-50%) translateY(40px) scale(.94);\n  padding: 10px 18px;\n  border-radius: 12px;\n  background: rgba(20, 24, 31, .94);\n  color: #fff;\n  font-family: var(--f-ui, 'Source Sans 3', system-ui, sans-serif);\n  font-size: 13px;\n  font-weight: 600;\n  letter-spacing: .02em;\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  box-shadow: 0 12px 32px rgba(0, 0, 0, .30);\n  opacity: 0;\n  pointer-events: none;\n  z-index: var(--z-toast, 9800);\n  transition:\n    opacity .28s var(--gb-ease-out, cubic-bezier(.2,.7,.2,1)),\n    transform .38s var(--gb-ease-spring, cubic-bezier(.34,1.56,.64,1));\n}\n.gb-fc-toast.is-open {\n  opacity: 1;\n  transform: translateX(-50%) translateY(0) scale(1);\n}\n.gb-fc-toast svg {\n  width: 16px;\n  height: 16px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 2;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  color: var(--color-accent-gold-bright, #d8aa6d);\n}\n\n/* =========================================================\n   gb-floater--series-lite — compact серийный кластер\n   (SeriesLiteCluster.astro)\n   ========================================================= */\n.gb-floater--series-lite {\n  position: fixed;\n  top: max(20px, env(safe-area-inset-top, 20px));\n  right: max(20px, env(safe-area-inset-right, 20px));\n  z-index: var(--z-toast, 9800);\n  display: flex;\n  flex-direction: column;\n  align-items: flex-end;\n  gap: 8px;\n  pointer-events: none;\n}\n\n.gb-floater--series-lite > * {\n  pointer-events: auto;\n}\n\n/* Серийный chip — ссылка к hub */\n.gb-series-chip {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n  min-width: 0;\n  padding: 8px 12px;\n  border: 1px solid color-mix(in srgb, var(--color-border, #e5e2dc) 88%, transparent);\n  border-radius: 14px;\n  background: color-mix(in srgb, var(--color-surface, #fff) 94%, transparent);\n  color: var(--color-text, #1a1a1a);\n  text-decoration: none;\n  box-shadow: 0 14px 36px -26px rgba(22, 15, 10, .28);\n  -webkit-backdrop-filter: blur(16px) saturate(150%);\n  backdrop-filter: blur(16px) saturate(150%);\n  transition:\n    border-color .22s var(--gb-ease-out, cubic-bezier(.2,.7,.2,1)),\n    box-shadow .22s var(--gb-ease-out, cubic-bezier(.2,.7,.2,1));\n}\n\n@media (hover: hover) and (pointer: fine) {\n  .gb-series-chip:hover {\n    border-color: var(--color-accent, #7a2e2e);\n    box-shadow: 0 16px 40px -24px rgba(22, 15, 10, .38);\n  }\n}\n\n.gb-series-chip__eyebrow {\n  font-family: var(--f-ui, 'Source Sans 3', system-ui, sans-serif);\n  font-size: 10px;\n  font-weight: 800;\n  letter-spacing: .14em;\n  text-transform: uppercase;\n  color: var(--color-accent, #7a2e2e);\n}\n\n.gb-series-chip__title {\n  font-family: var(--f-body, Lora, Georgia, serif);\n  font-size: 14px;\n  font-weight: 700;\n  line-height: 1.2;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  max-width: 160px;\n}\n\n/* Variant: pastor */\n.gb-floater--pastor .gb-series-chip__eyebrow {\n  color: color-mix(in srgb, var(--color-accent, #7a2e2e) 80%, #5b2b20 20%);\n}\n\n/* Variant: heart */\n.gb-floater--heart .gb-series-chip__eyebrow {\n  color: color-mix(in srgb, var(--color-accent, #7a2e2e) 85%, #8b0000 15%);\n}\n\n/* Controls pill */\n.gb-series-controls {\n  display: flex;\n  align-items: center;\n  gap: 4px;\n  padding: 3px;\n  border: 1px solid color-mix(in srgb, var(--color-border, #e5e2dc) 88%, transparent);\n  border-radius: 24px;\n  background: color-mix(in srgb, var(--color-surface, #fff) 94%, transparent);\n  box-shadow: 0 16px 38px -28px rgba(22, 15, 10, .24);\n  -webkit-backdrop-filter: blur(16px) saturate(150%);\n  backdrop-filter: blur(16px) saturate(150%);\n}\n\nhtml.dark .gb-series-controls,\nhtml.dark .gb-series-chip {\n  background: color-mix(in srgb, var(--color-surface, #161a21) 94%, transparent);\n  border-color: rgba(255, 255, 255, .08);\n}\n\n/* Index номер */\n.gb-series-index {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  min-width: 28px;\n  padding: 0 6px;\n  font-family: var(--f-body, Lora, Georgia, serif);\n  font-size: 14px;\n  font-weight: 700;\n  letter-spacing: .08em;\n  color: var(--color-accent, #7a2e2e);\n}\n\n/* Кнопки в controls */\n.gb-series-controls .gb-icon,\n.gb-series-controls .gb-ember,\n.gb-series-controls .gb-save {\n  width: 34px !important;\n  height: 34px !important;\n}\n\n.gb-series-controls .gb-ember {\n  --ember-size: 34px !important;\n}\n\n/* =========================================================\n   Mobile: horizontal pill\n   ========================================================= */\n@media (max-width: 899px) {\n  .gb-floater {\n    top: auto;\n    left: 50%;\n    right: auto;\n    bottom: calc(12px + env(safe-area-inset-bottom, 0px));\n    transform: translateX(-50%);\n    flex-direction: row;\n    gap: 2px;\n    padding: 3px;\n    border: 1px solid color-mix(in srgb, var(--color-border, #e5e2dc) 86%, transparent);\n    border-radius: 24px;\n    background: color-mix(in srgb, var(--color-surface, #fff) 94%, transparent);\n    -webkit-backdrop-filter: blur(16px) saturate(160%);\n    backdrop-filter: blur(16px) saturate(160%);\n    z-index: var(--z-bottom-bar, 2000);\n  }\n\n  html.dark .gb-floater {\n    background: color-mix(in srgb, var(--color-surface, #161a21) 94%, transparent);\n    border-color: rgba(255, 255, 255, 0.08);\n  }\n\n  body.gb-cluster-single-active .article-main {\n    padding-bottom: 88px;\n  }\n\n  /* Series-lite mobile */\n  .gb-floater--series-lite {\n    top: auto;\n    left: 50%;\n    right: auto;\n    bottom: calc(12px + env(safe-area-inset-bottom, 0px));\n    transform: translateX(-50%);\n    flex-direction: row;\n    align-items: stretch;\n    justify-content: center;\n    gap: 8px;\n    width: min(94vw, 420px);\n    z-index: var(--z-bottom-bar, 2000);\n  }\n\n  .gb-floater--series-lite .gb-series-chip {\n    flex: 1 1 auto;\n    min-width: 0;\n    justify-content: center;\n  }\n\n  body.gb-cluster-series-active .article-main,\n  body.fc-series-active .article-main {\n    padding-bottom: 96px;\n  }\n}\n\n/* =========================================================\n   Скрытие старых controls\n   ========================================================= */\nbody.gb-cluster-single-active #reading-progress,\nbody.gb-cluster-single-active #section-label,\nbody.gb-cluster-single-active #back-to-top,\nbody.gb-cluster-single-active #themeToggle,\nbody.gb-cluster-single-active #tocSidebar,\nbody.gb-cluster-single-active #bottomBar,\nbody.gb-cluster-single-active #btocOverlay,\nbody.fc-single-active #reading-progress,\nbody.fc-single-active #section-label,\nbody.fc-single-active #back-to-top,\nbody.fc-single-active #themeToggle,\nbody.fc-single-active #tocSidebar,\nbody.fc-single-active #bottomBar,\nbody.fc-single-active #btocOverlay {\n  display: none !important;\n}\n\nbody.gb-cluster-series-active #reading-progress,\nbody.gb-cluster-series-active #section-label,\nbody.gb-cluster-series-active #back-to-top,\nbody.gb-cluster-series-active #themeToggle,\nbody.gb-cluster-series-active #tocSidebar,\nbody.gb-cluster-series-active #bottomBar,\nbody.gb-cluster-series-active #btocOverlay,\nbody.fc-series-active #reading-progress,\nbody.fc-series-active #section-label,\nbody.fc-series-active #back-to-top,\nbody.fc-series-active #themeToggle,\nbody.fc-series-active #tocSidebar,\nbody.fc-series-active #bottomBar,\nbody.fc-series-active #btocOverlay {\n  display: none !important;\n}\n\n/* =========================================================\n   Reduced motion\n   ========================================================= */\n@media (prefers-reduced-motion: reduce) {\n  .gb-icon, .gb-ember, .gb-save, .gb-theme-toggle svg,\n  .gb-floater, .gb-floater--series-lite, .gb-fc-toast {\n    animation: none !important;\n    transition-duration: 0.01ms !important;\n  }\n}\n\n} /* @layer components */\n\n\n\n/* ===================================================================\n   Gill v16 Series Rail, Mobile Bar, TOC Popups\n   Scope: [data-gill-v16] wrapper on pilot page\n   Source: gb-floating-cluster-probe-v16.html (owner reference)\n   =================================================================== */\n\n\n/* ============================================================\n   v16 — Mobile TOC & Progress Redesign (owner approved):\n   1. TOC Progress Style: Thin elegant gold line (1.5px) in gold/amber tones.\n   2. Mobile TOC Popup Layout: Repacked bottom action bar for 320-390px screens.\n   3. Mobile Bottom Bar: Optimized spacing & compact typography for narrow screens.\n   4. Popup Overlays: Zero padding on mobile screens, full-width attachment.\n   ============================================================ */\n\n\n\n\n\n@media(max-width:680px){.state-grid{grid-template-columns:repeat(2,1fr)}}\n\n/* ============================================================\n   BARE SVG ICON — touch-aware + precision outline (v14)\n   ============================================================ */\n@media (hover: hover) and (pointer: fine) {\n  html.dark [data-gill-v16] .gb-icon:hover{color:var(--gb-accent-strong)}\n}\n@media (hover: hover) and (pointer: fine) {\n}\n\n@media (hover: hover) and (pointer: fine) {\n}\n\n/* ============================================================\n   v15: SAVE button — NO ::before halo (different from gb-icon)\n   Just gold fill on click + bounce. NO outline ring.\n   ============================================================ */\n/* NOTE: no ::before outline! Save is purely visual feedback */\n@media (hover: hover) and (pointer: fine) {\n}\n/* When saved: gold fill + bounce. NO halo. */\n@keyframes save-bounce{\n  0%{transform:scale(1)}\n  40%{transform:scale(1.30)}\n  70%{transform:scale(.92)}\n  100%{transform:scale(1)}\n}\n\n/* ============================================================\n   THEME TOGGLE — 180° rotation morph (v14)\n   ============================================================ */\nhtml.dark [data-gill-v16] .gb-theme-toggle .theme-icon-sun{opacity:0;transform:rotate(90deg) scale(.5)}\nhtml.dark [data-gill-v16] .gb-theme-toggle .theme-icon-moon{opacity:1;transform:rotate(0) scale(1)}\n@media (hover: hover) and (pointer: fine) {\n}\n\n/* ============================================================\n   PLAY EMBER (v14, fixed loading state in v15)\n   ============================================================ */\n@media (hover: hover) and (pointer: fine) {\n}\n\n\n/* v15: Loading pulse (fixed — only on ::before) */\n@keyframes loading-pulse{\n  0%,100%{opacity:0}\n  50%{opacity:0.5}\n}\n\n\n/* GBS RAIL */\n[data-gill-v16] .gbs-rail{\n  width:240px;display:flex;flex-direction:column;gap:10px;\n  padding:14px 12px 12px;border-radius:14px;\n  background:rgba(255,255,255,.045);\n  border:1px solid rgba(255,255,255,.08);\n  position:relative;\n}\n[data-gill-v16] .gbs-rail-back{\n  position:absolute;top:10px;left:10px;\n  width:36px;height:36px;\n  display:grid;place-items:center;\n  color:#eadac7;background:transparent;border:0;\n  transition:color .22s var(--gb-ease-out),transform .32s var(--gb-ease-spring);\n  cursor:pointer;transform-origin:center;\n}\n@media (hover: hover) and (pointer: fine) {\n[data-gill-v16] .gbs-rail-back:hover{color:#f4e8d9;transform:translateX(-2px) scale(1.10)}\n}\n[data-gill-v16] .gbs-rail-back:active{transform:translateX(-2px) scale(.92);transition:transform .12s}\n[data-gill-v16] .gbs-rail-back:focus-visible{outline:2px solid var(--gb-accent);outline-offset:2px;border-radius:50%}\n[data-gill-v16] .gbs-rail-back svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}\n\n[data-gill-v16] .gbs-rail-list{display:flex;flex-direction:column;gap:6px;margin-top:6px}\n[data-gill-v16] .gbs-rail-card{\n  display:grid;\n  grid-template-columns:36px 1fr auto auto;\n  gap:10px;\n  align-items:center;\n  padding:8px 10px;\n  border-radius:10px;\n  background:transparent;\n  border:1px solid transparent;\n  cursor:pointer;\n  transition:\n[data-gill-v16] background .28s var(--gb-ease-out),[data-gill-v16] \n[data-gill-v16] border-color .28s var(--gb-ease-out),[data-gill-v16] \n    transform .32s var(--gb-ease-spring);\n  position:relative;\n  transform-origin:left center;\n}\n@media (hover: hover) and (pointer: fine) {\n[data-gill-v16] .gbs-rail-card:hover{\n    background:rgba(255,255,255,.04);\n    border-color:rgba(255,255,255,.10);\n    transform:translateX(2px);\n  }\n}\n[data-gill-v16] .gbs-rail-card:active{transform:translateX(2px) scale(.99)}\n[data-gill-v16] .gbs-rail-card.is-current{\n  background:rgba(216,170,109,.08);\n  border-color:rgba(216,170,109,.30);\n}\n[data-gill-v16] .gbs-rail-card__num{\n  font-family:var(--gb-font-serif-display);\n  font-size:18px;font-weight:600;font-style:italic;letter-spacing:.02em;\n  color:var(--gb-accent-gold);text-align:center;line-height:1;\n  font-feature-settings:\"liga\",\"kern\";\n  transition:color .22s var(--gb-ease-out),transform .32s var(--gb-ease-spring);\n  flex-shrink:0;width:36px;height:28px;display:grid;place-items:center;\n  transform-origin:center;\n}\n@media (hover: hover) and (pointer: fi