=============================================== */\n\n/* v15: bottom-bar WITHOUT Save (now in TOC popup) */\n[data-gill-v16] .mobile-bottom-bar{\n  position:absolute;left:6px;right:6px;bottom:6px;\n  display:flex;align-items:center;justify-content:space-between;gap:4px;\n  padding:6px 8px;border-radius:20px;\n  background:rgba(253,252,249,.96);\n  border:1px solid var(--gb-border);\n  -webkit-backdrop-filter:blur(14px) saturate(160%);\n  backdrop-filter:blur(14px) saturate(160%);\n  box-shadow:0 8px 24px rgba(0,0,0,.10);\n  font-family:var(--gb-font-sans);font-size:11.5px;\n  z-index:var(--z-bottom-bar);\n  box-sizing:border-box;\n}\nhtml.dark [data-gill-v16] .mobile-bottom-bar{background:rgba(22,26,33,.96);border-color:rgba(255,255,255,.08)}\n\n[data-gill-v16] .mobile-toc-btn{\n  width:32px;height:32px;display:grid;place-items:center;\n  color:var(--gb-text);background:transparent;border:0;border-radius:50%;\n  transition:color .22s var(--gb-ease-out),transform .32s var(--gb-ease-spring);\n  cursor:pointer;flex-shrink:0;transform-origin:center;\n}\n[data-gill-v16] .mobile-toc-btn:active{transform:scale(.92)}\n[data-gill-v16] .mobile-toc-btn svg{width:17px;height:17px;stroke:currentColor;fill:none;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}\n\n[data-gill-v16] .mobile-btoc-section{\n  font-size:11px;color:var(--gb-text-muted);min-width:28px;\n  overflow:hidden;text-overflow:ellipsis;white-space:nowrap;\n  font-weight:700;flex-shrink:0;\n}\n\n/* v16: Elegant gold line progress bar instead of dots */\n[data-gill-v16] .mobile-btoc-progress-track{\n  flex:1 1 auto;max-width:80px;height:2.5px;border-radius:99px;background:color-mix(in srgb,var(--gb-accent-gold) 22%,transparent);overflow:hidden;position:relative;margin:0 4px;\n}\n[data-gill-v16] .mobile-btoc-progress-fill{\n  height:100%;background:linear-gradient(90deg,var(--gb-accent-gold-bright),var(--gb-accent-gold));border-radius:99px;box-shadow:0 0 6px rgba(216,170,109,.55);\n}\n[data-gill-v16] .mobi