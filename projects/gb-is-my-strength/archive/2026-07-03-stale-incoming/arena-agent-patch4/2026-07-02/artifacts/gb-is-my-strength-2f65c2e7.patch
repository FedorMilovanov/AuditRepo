ttps://gospod-bog.ru/baptisty-rossii/sovetskaya-noch/"}]}]}</script></head><body class="gbs-world" data-gbs2-series="russian-baptism" data-gbs2-done-min="100" data-gbs2-part-min="28" data-gbs2-total-min="229"><a class="skip-link" href="#main-content">Перейти к содержимому</a><div class="gbs2-mobile-head"><img src="../../images/baptisty-rossii/cover-06-soviet-night.svg" alt="Советская ночь — часть 6 серии" width="600" height="315"><div class="gbs2-mobile-title"><span>Баптисты России</span><b>6 · Советская ночь: закон 1929 года и репрессии</b></div><div class="gbs2-mobile-actions"><button class="gbs2-mctl" type="button" data-gbs2-theme aria-label="Переключить тему">◐</button><button class="gbs2-mctl" type="button" data-gbs2-search aria-label="Поиск">⌕</button></div></div><div class="gbs2-world"><aside class="gbs2-rail" aria-label="Серия «Баптисты России»"><div class="gbs2-rhead"><div class="gbs2-kicker">Серия · История ЕХБ</div><h2 class="gbs2-rtitle">Баптисты России</h2><div class="gbs2-rsub">10 частей · живая исследовательская серия</div><div class="gbs2-rprogress"><div class="gbs2-ring" aria-hidden="true"><svg width="44" height="44" viewBox="0 0 44 44"><circle class="t" cx="22" cy="22" r="18"></circle><circle class="f" id="gbs2Ring" cx="22" cy="22" r="18" stroke-dasharray="113" stroke-dashoffset="113"></circle></svg><b id="gbs2Pct">100%</b></div><div><small>Опубликовано</small><span id="gbs2Meta">6 из 10</span></div></div></div><div class="gbs2-rmid"><nav class="gbs2-parts" aria-label="Части серии"><a class="gbs2-part" href="../noch-na-kure/"><span class="gbs2-thumb"><img src="../../images/baptisty-rossii/cover-01-kura.svg" alt="Ночь на Куре — часть 1 серии" width="600" height="315" loading="lazy" decoding="async"></span><span><span class="gbs2-pn">1 · 18 мин</span><span class="gbs2-pt">Ночь на Куре</span><span class="gbs2-ps">Воронин, Кальвейт, Деляков и первая русска</span></span><span class="gbs2-check" aria-hidden="true">✓</span></a><a class="gbs2-part" href=".