-<link rel="alternate" type="application/rss+xml" title="Господь Бог — Сила Моя — RSS" href="https://gospod-bog.ru/feed.xml"><script type="application/ld+json">{"@context":"https://schema.org","@type":"SpeakableSpecification","cssSelector":["h1",".article-desc","[data-speakable]"]}</script><link rel="stylesheet" href="../../css/floating-cluster.css?v=91f72196"><script type="application/ld+json">{"@context":"https://schema.org","@graph":[{"@type":"Organization","@id":"https://gospod-bog.ru/#organization","name":"Господь Бог — Сила Моя","url":"https://gospod-bog.ru/","logo":{"@type":"ImageObject","url":"https://gospod-bog.ru/icons/icon-512.png","width":512,"height":512},"sameAs":["https://t.me/fedormilovanov","https://vk.com/curtmf"]},{"@type":"Article","headline":"Подпольная печать: Вестники, «Христианин» и память узников — Баптисты России","description":"Самиздат Совета Церквей: «Вестник спасения», «Вестник Истины», Совет родственников и издательство «Христианин».","url":"https://gospod-bog.ru/baptisty-rossii/podpolnaya-pechat/","inLanguage":"ru","author":{"@type":"Person","name":"Фёдор Милованов","url":"https://gospod-bog.ru/about/"},"publisher":{"@type":"Organization","name":"Господь Бог — Сила Моя","url":"https://gospod-bog.ru/"},"image":"https://gospod-bog.ru/images/baptisty-rossii/cover-09-samizdat.webp","datePublished":"2026-06-13T00:00:00+03:00","dateModified":"2026-06-25T17:00:00+03:00"},{"@type":"WebSite","@id":"https://gospod-bog.ru/#website","name":"Господь Бог — Сила Моя","url":"https://gospod-bog.ru/","inLanguage":"ru","potentialAction":{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://gospod-bog.ru/?q={search_term_string}"},"query-input":"required name=search_term_string"}},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://gospod-bog.ru/"},{"@type":"ListItem","position":2,"name":"Баптисты России","item":"https://gospod-bog.ru/baptisty-rossii/"},{"@type":"ListItem",