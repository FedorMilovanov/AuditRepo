169:    scriptTag('js/sw-register.js'),
170:    scriptTag('js/search.js'),

scriptTag function uses md5short() to add ?v=HASH:
function scriptTag(rel: string, attrs = 'defer') {
  const hash = md5short(rel);
  const src = `/${rel}${hash ? `?v=${hash}` : ''}`;
  return `<script ${attrs} src="${src}"></script>`;

CONCLUSION: JS gets cache-busting, CSS does NOT
