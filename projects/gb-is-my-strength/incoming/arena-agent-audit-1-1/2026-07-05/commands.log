# og:image vs LCP mismatch
python3 -c "
import re
for f in ['articles/20-antisovetov-pastoru/index.html','articles/kod-da-vinchi/index.html','index.html','pastor-series/index.html']:
    html = open(f).read()
    og = re.search(r'<meta[^>]+property=[\"'\'']og:image[\"'\''][^>]+content=[\"'\'']([^\"'\'']+)', html)
    lcp = re.findall(r'<img[^>]+fetchpriority=[\"'\'']high[\"'\''][^>]+src=[\"'\'']([^"'\'']+)', html)
    print(f'{f}: og={og.group(1) if og else \"?\"}, lcp={lcp[:2]}')
"

